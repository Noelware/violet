From 567faa3569adb40c45611db4d74b299c19eafdff Mon Sep 17 00:00:00 2001
From: Travis Downs <travis.downs@redpanda.com>
Date: Wed, 1 Apr 2026 12:40:38 -0300
Subject: [PATCH 2/4] liburing@2.14.bcr.1: rework configure genrule to
 out-of-source build

Replace pushd/popd with symlink-based out-of-source build so that
CWD does not change and relative paths (e.g., --sysroot) resolve
correctly. Also simplify output copying to use parameter expansion
instead of realpath.

Upstream now supports out-of-source builds natively
(https://github.com/axboe/liburing/pull/1558) but that landed after
the 2.14 release, so this workaround is needed for the current BCR
version.
---
 modules/liburing/2.14.bcr.1/overlay/BUILD.bazel | 16 ++++++++++------
 modules/liburing/2.14.bcr.1/source.json         |  2 +-
 2 files changed, 11 insertions(+), 7 deletions(-)

diff --git a/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel b/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
index 8befe6063f3..846370422c1 100644
--- a/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
+++ b/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
@@ -22,15 +22,19 @@ genrule(
     cmd = """
             export CC=$(CC) CXX=$(CC)++
 
-            # switch to the package dir to execute "configure" right there
-            pushd $$(dirname $(location configure))
-              mkdir -p src/include/liburing
-              ./configure --use-libc
-            popd
+            # We do an out-of-source build here so that CWD does not
+            # change and relative paths (e.g., sysroot) work correctly.
+            # liburing doesn't support out-of-source builds natively,
+            # so we fake it with symlinks.
+            pkg_dir=$$(dirname $(location configure))
+            ln -sf $$pkg_dir/Makefile.common Makefile.common
+            ln -sf $$pkg_dir/liburing.spec liburing.spec
+            mkdir -p src/include/liburing
+            $$pkg_dir/configure --use-libc
 
             # collect the outputs
             for out in $(OUTS); do
-              cp $$(realpath --relative-to=$(BINDIR) $$out) $$out
+              cp $${out#$(RULEDIR)/} $$out
             done
           """,
     toolchains = ["@bazel_tools//tools/cpp:current_cc_toolchain"],
diff --git a/modules/liburing/2.14.bcr.1/source.json b/modules/liburing/2.14.bcr.1/source.json
index 3dfd2865f70..a4aa059c39c 100644
--- a/modules/liburing/2.14.bcr.1/source.json
+++ b/modules/liburing/2.14.bcr.1/source.json
@@ -3,7 +3,7 @@
     "integrity": "sha256-X4CWQQiYHGrZecc18LSHfV9JkUwqBi+OiCgvJr9h3gw=",
     "strip_prefix": "liburing-liburing-2.14",
     "overlay": {
-        "BUILD.bazel": "sha256-kGSANWQ6XWFmBYDIe8xKPvnn4NplBczFVSDJDUgd/jM=",
+        "BUILD.bazel": "sha256-c6m9lAGDX0JV6uWjCe5ReBnvuvJNGNHB3lgMCjktlWU=",
         "MODULE.bazel": "sha256-bf6db5qgdCG13fl0O2C8EoMoVxE7eg6sLYm9CSz8VUQ="
     }
 }

From 025afd1cccd61f1a5a7668df4c1082d939cc0fbb Mon Sep 17 00:00:00 2001
From: Travis Downs <travis.downs@redpanda.com>
Date: Wed, 1 Apr 2026 12:41:02 -0300
Subject: [PATCH 3/4] liburing@2.14.bcr.1: propagate toolchain flags to
 configure

Pass CFLAGS="$(CC_FLAGS)" so configure probes use the same flags
as cc_library rules. Pass LDFLAGS="-c" to skip linking in configure
probes: none of the configure tests execute the output and they are
all effectively compile-time checks of headers and compiler features,
so compile-only is sufficient. Without this, the system linker may
fail on sysroot linker scripts on non-Debian distros (e.g., Fedora).

LDFLAGS="-c" is the best workaround given that Bazel's cc toolchain
does not expose a $(LDFLAGS) Make variable for genrules.
---
 modules/liburing/2.14.bcr.1/overlay/BUILD.bazel | 7 +++++--
 modules/liburing/2.14.bcr.1/source.json         | 2 +-
 2 files changed, 6 insertions(+), 3 deletions(-)

diff --git a/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel b/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
index 846370422c1..a2d5c644ce3 100644
--- a/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
+++ b/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
@@ -20,7 +20,7 @@ genrule(
         "src/include/liburing/io_uring_version.h",
     ],
     cmd = """
-            export CC=$(CC) CXX=$(CC)++
+            export CC=$(CC) CXX=$(CC)++ CFLAGS="$(CC_FLAGS)" LDFLAGS="-c"
 
             # We do an out-of-source build here so that CWD does not
             # change and relative paths (e.g., sysroot) work correctly.
@@ -37,7 +37,10 @@ genrule(
               cp $${out#$(RULEDIR)/} $$out
             done
           """,
-    toolchains = ["@bazel_tools//tools/cpp:current_cc_toolchain"],
+    toolchains = [
+        "@bazel_tools//tools/cpp:current_cc_toolchain",
+        "@bazel_tools//tools/cpp:cc_flags",
+    ],
     tools = ["configure"],
 )
 
diff --git a/modules/liburing/2.14.bcr.1/source.json b/modules/liburing/2.14.bcr.1/source.json
index a4aa059c39c..f5d0ea9e1cf 100644
--- a/modules/liburing/2.14.bcr.1/source.json
+++ b/modules/liburing/2.14.bcr.1/source.json
@@ -3,7 +3,7 @@
     "integrity": "sha256-X4CWQQiYHGrZecc18LSHfV9JkUwqBi+OiCgvJr9h3gw=",
     "strip_prefix": "liburing-liburing-2.14",
     "overlay": {
-        "BUILD.bazel": "sha256-c6m9lAGDX0JV6uWjCe5ReBnvuvJNGNHB3lgMCjktlWU=",
+        "BUILD.bazel": "sha256-VmpCPOmogHBfWoRJIkTTolSYvaUKJD9JexU7K83QEo4=",
         "MODULE.bazel": "sha256-bf6db5qgdCG13fl0O2C8EoMoVxE7eg6sLYm9CSz8VUQ="
     }
 }

From e13c73e78a8aae605b6e9fae20f48779c8ba3cee Mon Sep 17 00:00:00 2001
From: Travis Downs <travis.downs@redpanda.com>
Date: Wed, 1 Apr 2026 12:41:20 -0300
Subject: [PATCH 4/4] liburing@2.14.bcr.1: suppress -Wunused-parameter warnings

Upstream liburing has unused parameters in register.c that trigger
-Wunused-parameter from -Wextra. A fix is pending upstream
(https://github.com/axboe/liburing/pull/1564) but for this release
we suppress the warning with -Wno-unused-parameter.
---
 modules/liburing/2.14.bcr.1/overlay/BUILD.bazel | 1 +
 modules/liburing/2.14.bcr.1/source.json         | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel b/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
index a2d5c644ce3..0c16ad1228b 100644
--- a/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
+++ b/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
@@ -70,6 +70,7 @@ cc_library(
         "-DLIBURING_INTERNAL",
         "-Wall",
         "-Wextra",
+        "-Wno-unused-parameter",
         "-fno-stack-protector",
         "-include config-host.h",
     ],
diff --git a/modules/liburing/2.14.bcr.1/source.json b/modules/liburing/2.14.bcr.1/source.json
index f5d0ea9e1cf..6c7091f4634 100644
--- a/modules/liburing/2.14.bcr.1/source.json
+++ b/modules/liburing/2.14.bcr.1/source.json
@@ -3,7 +3,7 @@
     "integrity": "sha256-X4CWQQiYHGrZecc18LSHfV9JkUwqBi+OiCgvJr9h3gw=",
     "strip_prefix": "liburing-liburing-2.14",
     "overlay": {
-        "BUILD.bazel": "sha256-VmpCPOmogHBfWoRJIkTTolSYvaUKJD9JexU7K83QEo4=",
+        "BUILD.bazel": "sha256-FcUPlEf4Psog6VHI15KeKCJksG7nipYY/nYc57jcE2g=",
         "MODULE.bazel": "sha256-bf6db5qgdCG13fl0O2C8EoMoVxE7eg6sLYm9CSz8VUQ="
     }
 }
