From fa9031e11304030688f30c6b3b90e8013cb9d34c Mon Sep 17 00:00:00 2001
From: Travis Downs <travis.downs@redpanda.com>
Date: Wed, 1 Apr 2026 12:40:15 -0300
Subject: [PATCH 1/4] liburing@2.14.bcr.1: copy 2.14 module as base for
 registry fixes

Verbatim copy of the 2.14 overlay with version bumped to 2.14.bcr.1.
Subsequent commits apply the actual fixes.
---
 modules/liburing/2.14.bcr.1/MODULE.bazel      |  8 ++
 .../liburing/2.14.bcr.1/overlay/BUILD.bazel   | 77 +++++++++++++++++++
 .../liburing/2.14.bcr.1/overlay/MODULE.bazel  |  8 ++
 modules/liburing/2.14.bcr.1/presubmit.yml     | 18 +++++
 modules/liburing/2.14.bcr.1/source.json       |  9 +++
 modules/liburing/metadata.json                |  3 +-
 6 files changed, 122 insertions(+), 1 deletion(-)
 create mode 100644 modules/liburing/2.14.bcr.1/MODULE.bazel
 create mode 100644 modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
 create mode 100644 modules/liburing/2.14.bcr.1/overlay/MODULE.bazel
 create mode 100644 modules/liburing/2.14.bcr.1/presubmit.yml
 create mode 100644 modules/liburing/2.14.bcr.1/source.json

diff --git a/modules/liburing/2.14.bcr.1/MODULE.bazel b/modules/liburing/2.14.bcr.1/MODULE.bazel
new file mode 100644
index 00000000000..2f86246fb1d
--- /dev/null
+++ b/modules/liburing/2.14.bcr.1/MODULE.bazel
@@ -0,0 +1,8 @@
+module(
+    name = "liburing",
+    version = "2.14.bcr.1",
+    bazel_compatibility = [">=7.2.1"],
+    compatibility_level = 1,
+)
+
+bazel_dep(name = "rules_cc", version = "0.2.17")
diff --git a/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel b/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
new file mode 100644
index 00000000000..8befe6063f3
--- /dev/null
+++ b/modules/liburing/2.14.bcr.1/overlay/BUILD.bazel
@@ -0,0 +1,77 @@
+# SPDX-License-Identifier: Apache-2.0
+
+load("@rules_cc//cc:defs.bzl", "cc_library")
+
+# This genrule facilitates the installed kernel headers to configure a
+# compatibility header file. While that effectively breaks hermeticity, there
+# is not much we can do about that. We can't really bring the kernel headers
+# into BCR as they correspond to the host kernel. The good news is that the
+# resulting library is portable due to the compatibility layer at compile
+# time.
+genrule(
+    name = "generate_headers",
+    srcs = [
+        "Makefile.common",
+        "liburing.spec",
+    ],
+    outs = [
+        "config-host.h",
+        "src/include/liburing/compat.h",
+        "src/include/liburing/io_uring_version.h",
+    ],
+    cmd = """
+            export CC=$(CC) CXX=$(CC)++
+
+            # switch to the package dir to execute "configure" right there
+            pushd $$(dirname $(location configure))
+              mkdir -p src/include/liburing
+              ./configure --use-libc
+            popd
+
+            # collect the outputs
+            for out in $(OUTS); do
+              cp $$(realpath --relative-to=$(BINDIR) $$out) $$out
+            done
+          """,
+    toolchains = ["@bazel_tools//tools/cpp:current_cc_toolchain"],
+    tools = ["configure"],
+)
+
+cc_library(
+    name = "uring",
+    srcs = [
+        "config-host.h",
+        "src/include/liburing/compat.h",
+        "src/include/liburing/io_uring_version.h",
+        "src/queue.c",
+        "src/register.c",
+        "src/setup.c",
+        "src/syscall.c",
+        "src/version.c",
+    ] + glob([
+        "src/arch/**/*.h",
+        "src/*.h",
+    ]),
+    hdrs = glob(["src/include/**/*.h"]),
+
+    # cflags aligned with upstream:
+    # https://github.com/axboe/liburing/blob/master/src/Makefile#L13
+    copts = [
+        "-D_GNU_SOURCE",
+        "-D_LARGEFILE_SOURCE",
+        "-D_FILE_OFFSET_BITS=64",
+        "-DLIBURING_INTERNAL",
+        "-Wall",
+        "-Wextra",
+        "-fno-stack-protector",
+        "-include config-host.h",
+    ],
+    includes = ["src/include"],
+    visibility = ["//visibility:public"],
+)
+
+alias(
+    name = "liburing",
+    actual = ":uring",
+    visibility = ["//visibility:public"],
+)
diff --git a/modules/liburing/2.14.bcr.1/overlay/MODULE.bazel b/modules/liburing/2.14.bcr.1/overlay/MODULE.bazel
new file mode 100644
index 00000000000..2f86246fb1d
--- /dev/null
+++ b/modules/liburing/2.14.bcr.1/overlay/MODULE.bazel
@@ -0,0 +1,8 @@
+module(
+    name = "liburing",
+    version = "2.14.bcr.1",
+    bazel_compatibility = [">=7.2.1"],
+    compatibility_level = 1,
+)
+
+bazel_dep(name = "rules_cc", version = "0.2.17")
